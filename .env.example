# .env.example — plantilla de variables de entorno (motor de ventas IA)
#
# Copia este archivo a `.env` y rellena los valores. NUNCA subas `.env` al repo.
# Todos los secretos viven aquí (fuera del código y fuera de git).
#
#   cp .env.example .env
#   # luego edita .env con tus credenciales

# --- Modelo de IA (Anthropic / Claude) ---
ANTHROPIC_API_KEY=
CLAUDE_MODEL_MAIN=
CLAUDE_MODEL_CHEAP=

# --- Embeddings (OpenAI) — usados por el RAG del catálogo ---
OPENAI_API_KEY=

# --- Base de datos y backend (Supabase) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # admin-only: NO compartir, solo backend de confianza

# --- Orquestador (n8n) ---
N8N_BASE_URL=
N8N_API_KEY=

# --- Observabilidad (Langfuse) ---
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Canal WhatsApp (Meta Cloud API) ---
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_NOTIFY_ENABLED=
WHATSAPP_NOTIFY_TARGET=        # número E.164 que recibe avisos del agente

# --- Agenda (Google Calendar, service account) ---
GOOGLE_CALENDAR_SA_JSON_PATH=
GOOGLE_CALENDAR_SA_EMAIL=
GOOGLE_CALENDAR_DEFAULT_TZ=

# --- Pagos (Mercado Pago) — opcional ---
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
